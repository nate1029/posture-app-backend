<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup + device-transfer rules. Mirrors backup_rules.xml.
  See https://developer.android.com/about/versions/12/backup-restore for syntax.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="neckguard_secure_prefs.xml"/>
        <exclude domain="sharedpref" path="neckguard_prefs_fallback.xml"/>
        <exclude domain="sharedpref" path="neckguard_crashes.xml"/>
        <exclude domain="database" path="neckguard_db"/>
        <exclude domain="database" path="neckguard_db-shm"/>
        <exclude domain="database" path="neckguard_db-wal"/>
        <exclude domain="database" path="neckguard_db-journal"/>
    </cloud-backup>

    <device-transfer>
        <exclude domain="sharedpref" path="neckguard_secure_prefs.xml"/>
        <exclude domain="sharedpref" path="neckguard_prefs_fallback.xml"/>
        <exclude domain="sharedpref" path="neckguard_crashes.xml"/>
        <exclude domain="database" path="neckguard_db"/>
        <exclude domain="database" path="neckguard_db-shm"/>
        <exclude domain="database" path="neckguard_db-wal"/>
        <exclude domain="database" path="neckguard_db-journal"/>
    </device-transfer>
</data-extraction-rules>
