<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto-Backup rules (Android 6.0 – 11). On Android 12+, data_extraction_rules.xml
  is honoured instead. We exclude any file that contains either:
    • Encrypted blobs whose master key lives in the device KeyStore — these are
      unreadable on a different device, so backing them up just produces a
      corrupted prefs file on restore (silent login loss).
    • Plaintext sensitive data (crash traces, fallback prefs, posture history).
-->
<full-backup-content>
    <!-- Encrypted auth tokens, user profile, gamification state -->
    <exclude domain="sharedpref" path="neckguard_secure_prefs.xml"/>

    <!-- Plaintext fallback used only when KeyStore is unavailable -->
    <exclude domain="sharedpref" path="neckguard_prefs_fallback.xml"/>

    <!-- Plaintext stack traces queued for upload -->
    <exclude domain="sharedpref" path="neckguard_crashes.xml"/>

    <!-- Posture history / sensor logs -->
    <exclude domain="database" path="neckguard_db"/>
    <exclude domain="database" path="neckguard_db-shm"/>
    <exclude domain="database" path="neckguard_db-wal"/>
    <exclude domain="database" path="neckguard_db-journal"/>
</full-backup-content>
